{
  "name": "@kcosr/keel",
  "version": "0.0.0",
  "description": "Durable agent-workflow orchestrator",
  "type": "module",
  "private": true,
  "module": "src/index.ts",
  "exports": {
    ".": "./src/sdk.ts"
  },
  "bin": {
    "keel": "src/cli/keel.ts"
  },
  "scripts": {
    "build": "bun build src/cli/keel.ts --compile --outfile dist/keel",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
