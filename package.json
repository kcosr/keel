{
  "name": "@kcosr/keel",
  "version": "0.0.0",
  "description": "Durable agent-workflow orchestrator",
  "type": "module",
  "private": true,
  "workspaces": ["web"],
  "module": "src/index.ts",
  "exports": {
    ".": "./src/sdk.ts",
    "./execute": "./src/execute/index.ts",
    "./secrets": "./src/agents/secrets.ts"
  },
  "bin": {
    "keel": "src/cli/keel.ts"
  },
  "scripts": {
    "build": "bun build src/cli/keel.ts --compile --outfile dist/keel",
    "defaults:seed": "bash scripts/seed-default-profiles.sh --all",
    "profiles:seed-defaults": "bash scripts/seed-default-profiles.sh --profiles",
    "workflows:seed-defaults": "bash scripts/seed-default-profiles.sh --workflows",
    "test": "bun test --isolate ./src ./workflows ./fixtures",
    "typecheck": "tsc --noEmit && bun run web:typecheck",
    "lint": "biome check src web",
    "lint:fix": "biome check --write src web",
    "web:dev": "bun --cwd web vite --host 127.0.0.1",
    "web:build": "bun --cwd web vite build",
    "web:preview": "bun --cwd web vite preview --host 127.0.0.1",
    "web:test": "bun --cwd web vitest run --config vitest.config.ts",
    "web:typecheck": "bun --cwd web tsc --noEmit"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "typescript": "^5.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
